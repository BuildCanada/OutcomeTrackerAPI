<div class="space-y-8 p-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-gray-900">Scraping Health</h1>
    <span class="inline-flex items-center rounded-full px-3 py-1 text-sm font-medium
      <%= @unscraped_entries.count > 0 ? 'bg-red-100 text-red-800' : 'bg-green-100 text-green-800' %>">
      <%= @unscraped_entries.count %> unscraped
    </span>
  </div>

  <%# ── Feed Breakdown ── %>
  <div>
    <h2 class="text-lg font-semibold text-gray-700 mb-3">By Feed</h2>
    <% if @feeds_breakdown.any? %>
      <div class="overflow-x-auto rounded-lg border border-gray-200">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Feed</th>
              <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">Unscraped</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Last Scraped</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Last Failed</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Error</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @feeds_breakdown.each do |fb| %>
              <tr>
                <td class="px-4 py-3 text-sm text-gray-900">
                  <%= link_to fb[:feed_title], avo.resources_feed_path(fb[:feed_id]), class: "text-blue-600 hover:underline" %>
                </td>
                <td class="px-4 py-3 text-sm text-right font-medium text-red-600"><%= fb[:unscraped_count] %></td>
                <td class="px-4 py-3 text-sm text-gray-500">
                  <%= fb[:last_scraped_at] ? time_ago_in_words(fb[:last_scraped_at]) + " ago" : "Never" %>
                </td>
                <td class="px-4 py-3 text-sm text-gray-500">
                  <%= fb[:last_scrape_failed_at] ? time_ago_in_words(fb[:last_scrape_failed_at]) + " ago" : "—" %>
                </td>
                <td class="px-4 py-3 text-sm text-gray-500 max-w-xs truncate" title="<%= fb[:error_message] %>">
                  <%= fb[:error_message] || "—" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p class="text-gray-500 italic">All entries have been scraped.</p>
    <% end %>
  </div>

  <%# ── Entry List with Selection ── %>
  <div>
    <h2 class="text-lg font-semibold text-gray-700 mb-3">
      Unscraped Entries
      <span class="text-sm font-normal text-gray-400">(most recent 100)</span>
    </h2>

    <% if @entries.any? %>
      <%= form_tag main_app.avo_scraping_health_requeue_path, method: :post, id: "requeue-form" do %>
        <div class="mb-3 flex items-center gap-3">
          <button type="submit" class="inline-flex items-center gap-2 rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 disabled:opacity-50 disabled:cursor-not-allowed" id="requeue-btn" disabled>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
            </svg>
            Requeue Selected
          </button>
          <button type="button" class="text-sm text-blue-600 hover:underline" id="select-all-btn">Select all</button>
          <button type="button" class="text-sm text-gray-500 hover:underline" id="deselect-all-btn">Deselect all</button>
          <span class="text-sm text-gray-500" id="selection-count">0 selected</span>
        </div>

        <div class="overflow-x-auto rounded-lg border border-gray-200">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-4 py-3 w-10">
                  <input type="checkbox" id="header-checkbox" class="rounded border-gray-300 text-blue-600 focus:ring-blue-500">
                </th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Title</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Feed</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Created</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Published</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">URL</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% @entries.each do |entry| %>
                <tr class="hover:bg-gray-50">
                  <td class="px-4 py-3">
                    <input type="checkbox" name="entry_ids[]" value="<%= entry.id %>" class="entry-checkbox rounded border-gray-300 text-blue-600 focus:ring-blue-500">
                  </td>
                  <td class="px-4 py-3 text-sm text-gray-900">
                    <%= link_to (entry.title.presence || "Untitled"), avo.resources_entry_path(entry), class: "text-blue-600 hover:underline" %>
                  </td>
                  <td class="px-4 py-3 text-sm text-gray-500"><%= entry.feed.title %></td>
                  <td class="px-4 py-3 text-sm text-gray-500"><%= time_ago_in_words(entry.created_at) %> ago</td>
                  <td class="px-4 py-3 text-sm text-gray-500">
                    <%= entry.published_at ? time_ago_in_words(entry.published_at) + " ago" : "—" %>
                  </td>
                  <td class="px-4 py-3 text-sm text-gray-500 max-w-xs truncate">
                    <%= link_to entry.url, entry.url, target: "_blank", class: "text-blue-600 hover:underline", title: entry.url %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% end %>
    <% else %>
      <p class="text-gray-500 italic">No unscraped entries.</p>
    <% end %>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    const checkboxes = document.querySelectorAll(".entry-checkbox");
    const headerCheckbox = document.getElementById("header-checkbox");
    const requeueBtn = document.getElementById("requeue-btn");
    const selectionCount = document.getElementById("selection-count");
    const selectAllBtn = document.getElementById("select-all-btn");
    const deselectAllBtn = document.getElementById("deselect-all-btn");

    function updateState() {
      const checked = document.querySelectorAll(".entry-checkbox:checked");
      requeueBtn.disabled = checked.length === 0;
      selectionCount.textContent = checked.length + " selected";
      headerCheckbox.checked = checked.length === checkboxes.length && checkboxes.length > 0;
      headerCheckbox.indeterminate = checked.length > 0 && checked.length < checkboxes.length;
    }

    checkboxes.forEach(function(cb) { cb.addEventListener("change", updateState); });

    headerCheckbox.addEventListener("change", function() {
      checkboxes.forEach(function(cb) { cb.checked = headerCheckbox.checked; });
      updateState();
    });

    selectAllBtn.addEventListener("click", function() {
      checkboxes.forEach(function(cb) { cb.checked = true; });
      updateState();
    });

    deselectAllBtn.addEventListener("click", function() {
      checkboxes.forEach(function(cb) { cb.checked = false; });
      updateState();
    });
  });
</script>
